<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Squirrel.App.Views.NudgeWindow"
        Width="360" SizeToContent="Height"
        CanResize="False"
        SystemDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Background="{DynamicResource CardBrush}">

    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="16">
        <StackPanel Spacing="10">
            <TextBlock Text="🐿️ Squirrel" FontWeight="SemiBold" Opacity="0.8" />
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="14" />
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="LaterButton" Content="Later" />
                <Button x:Name="ShowButton" Content="Show me" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
